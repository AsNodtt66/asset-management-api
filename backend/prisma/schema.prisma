// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

// --- RBAC (Role-Based Access Control) ---
model Role {
  id               Int               @id @default(autoincrement())
  name             String            @unique
  users            User[]
  routingTables    RoutingTable[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([name])
}

model User {
  id                Int               @id @default(autoincrement())
  email             String            @unique
  password          String
  name              String
  roleId            Int
  role              Role              @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  // Asset Assignments
  assetAssignments  AssetAssignment[]
  
  // Warehouse Management
  goodsReceipts     GoodsReceipt[]
  goodsIssues       GoodsIssue[]
  
  // Issue Management - Distinct relations with explicit names
  issuesReported    Issue[]           @relation("ReportedBy")
  issuesAssigned    Issue[]           @relation("AssignedTo")
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([roleId])
  @@index([email])
}

// --- Asset Management ---
model Asset {
  id                Int               @id @default(autoincrement())
  name              String
  description       String?
  serialNo          String            @unique
  status            String            @default("AVAILABLE") // AVAILABLE, ASSIGNED, MAINTENANCE, RETIRED
  components        Component[]
  assignments       AssetAssignment[]
  issues            Issue[]
  maintenanceCards  MaintenanceCard[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([status])
  @@index([serialNo])
}

model Component {
  id                Int               @id @default(autoincrement())
  name              String
  assetId           Int
  asset             Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  status            String            @default("ACTIVE") // ACTIVE, MAINTENANCE, RETIRED
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([assetId])
  @@index([status])
}

model AssetAssignment {
  id                Int               @id @default(autoincrement())
  assetId           Int
  asset             Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId            Int
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt        DateTime          @default(now())
  unassignedAt      DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([assetId, userId])
  @@index([assetId])
  @@index([userId])
}

// --- Warehouse Management ---
model GoodsReceipt {
  id                Int               @id @default(autoincrement())
  itemName          String
  quantity          Int
  supplier          String?
  receiptDate       DateTime          @default(now())
  userId            Int
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([userId])
  @@index([receiptDate])
}

model GoodsIssue {
  id                Int               @id @default(autoincrement())
  itemName          String
  quantity          Int
  issuedTo          String?
  issueDate         DateTime          @default(now())
  userId            Int
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([userId])
  @@index([issueDate])
}

// --- Maintenance Routing ---
model MaintenanceCategory {
  id                Int               @id @default(autoincrement())
  name              String            @unique
  routingTables     RoutingTable[]
  maintenanceCards  MaintenanceCard[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([name])
}

model RoutingTable {
  id                Int               @id @default(autoincrement())
  categoryId        Int
  category          MaintenanceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  stepNo            Int
  description       String
  assignedRoleId    Int?
  assignedRole      Role?             @relation(fields: [assignedRoleId], references: [id], onDelete: SetNull)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([categoryId, stepNo])
  @@index([categoryId])
  @@index([assignedRoleId])
}

model MaintenanceCard {
  id                Int               @id @default(autoincrement())
  assetId           Int
  asset             Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  categoryId        Int
  category          MaintenanceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  issueId           Int?
  issue             Issue?            @relation(fields: [issueId], references: [id], onDelete: SetNull)
  currentStep       Int               @default(1)
  status            String            @default("OPEN") // OPEN, IN_PROGRESS, COMPLETED
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([assetId])
  @@index([categoryId])
  @@index([issueId])
  @@index([status])
}

// --- Issues Management ---
model Issue {
  id                Int               @id @default(autoincrement())
  assetId           Int
  asset             Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  reportedById      Int
  reportedBy        User              @relation("ReportedBy", fields: [reportedById], references: [id], onDelete: Cascade)
  assignedToId      Int?
  assignedTo        User?             @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  description       String
  status            String            @default("OPEN") // OPEN, ASSIGNED, IN_PROGRESS, RESOLVED
  maintenanceCards  MaintenanceCard[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([assetId])
  @@index([reportedById])
  @@index([assignedToId])
  @@index([status])
}