# ====== DATABASE ======
# PostgreSQL Connection String
# Format: postgresql://username:password@localhost:5432/database_name
DATABASE_URL="postgresql://user:password@localhost:5432/asset_management"

# ====== JWT ======
# Secret key untuk signing JWT tokens (gunakan yang kuat dan panjang di production)
JWT_SECRET="your-super-secret-key-change-this-in-production-min-32-chars"

# ====== SERVER ======
# Server port
PORT=3000

# Node environment (development, production, staging)
NODE_ENV="development"

# Log level (debug, info, warn, error, fatal)
LOG_LEVEL="info"

# ====== CORS ======
# CORS origin (gunakan * untuk development, spesifik URL untuk production)
CORS_ORIGIN="*"

# ====== API ======
# Base URL untuk production
API_URL="http://localhost:3000"

# ====== DATABASE MIGRATION ======
# Gunakan untuk development/testing
DATABASE_URL_SHADOW="postgresql://user:password@localhost:5432/asset_management_test"
